# Supabase — skopiuj do .env.local i uzupełnij (Project Settings → API).
# Bez tych zmiennych aplikacja działa w trybie lokalnym (tylko offline, bez kont).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Mapa offline: URL do pliku PMTiles (np. Cloudflare R2 / własny CDN).
# Bez tego mapa próbuje użyć stylu rastrowego (patrz src/lib/mapStyle.ts).
VITE_PMTILES_URL=
